<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Martech Expo 2026 · Recap by NitrogenZ.</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#080808;--s1:#111;--s2:#181818;--s3:#1f1f1f;
  --pk:#f72585;--pk2:#ff5ca8;--pk3:rgba(247,37,133,.12);
  --wh:#fff;--wh2:#f0f0f0;--wh3:rgba(255,255,255,.08);--wh4:rgba(255,255,255,.04);
  --bd:rgba(255,255,255,.08);--bd2:rgba(247,37,133,.2);
  --muted:#555;--muted2:#999;
  --font:'IBM Plex Sans Thai','IBM Plex Sans',sans-serif;
  --mono:'IBM Plex Mono',monospace;
}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--wh2);font-family:var(--font);overflow-x:hidden;min-height:100vh;}
body::before{content:'';position:fixed;inset:0;
  background-image:
    repeating-linear-gradient(135deg,transparent,transparent 60px,rgba(247,37,133,.022) 60px,rgba(247,37,133,.022) 61px),
    repeating-linear-gradient(45deg,transparent,transparent 80px,rgba(255,255,255,.012) 80px,rgba(255,255,255,.012) 81px);
  pointer-events:none;z-index:0;}
body::after{content:'';position:fixed;inset:0;
  background:radial-gradient(ellipse 60% 40% at 5% 0%,rgba(247,37,133,.07) 0%,transparent 55%),
    radial-gradient(ellipse 50% 50% at 95% 100%,rgba(247,37,133,.05) 0%,transparent 55%);
  pointer-events:none;z-index:0;}

/* ══ LOGIN ══ */
#login-screen{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;align-items:center;justify-content:center;}
#login-screen::before{content:'';position:absolute;inset:0;
  background-image:repeating-linear-gradient(135deg,transparent,transparent 60px,rgba(247,37,133,.03) 60px,rgba(247,37,133,.03) 61px);}
.login-box{position:relative;z-index:1;width:100%;max-width:360px;padding:0 24px;animation:fadeDown .8s ease both;}
.login-logo{text-align:center;margin-bottom:36px;}
.login-logo .eyebrow{font-family:var(--mono);font-size:10px;color:var(--muted2);letter-spacing:3px;text-transform:uppercase;display:flex;align-items:center;justify-content:center;gap:6px;}
.login-logo .eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--pk);animation:pulse 2s infinite;}
.login-logo h2{font-size:28px;font-weight:700;margin-top:12px;background:linear-gradient(135deg,#fff 40%,var(--pk));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1.2;}
.login-logo p{font-size:12px;color:var(--muted2);margin-top:6px;}
.lf{margin-bottom:14px;}
.lf label{display:block;font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted2);margin-bottom:7px;}
.lf input{width:100%;background:var(--s2);border:1px solid var(--bd);border-radius:10px;padding:12px 15px;font-family:var(--font);font-size:14px;color:var(--wh);outline:none;transition:border .2s,box-shadow .2s;}
.lf input:focus{border-color:var(--pk);box-shadow:0 0 0 3px rgba(247,37,133,.12);}
.login-btn{width:100%;margin-top:6px;background:var(--pk);border:none;border-radius:10px;padding:13px;font-family:var(--font);font-size:14px;font-weight:700;color:#fff;cursor:pointer;transition:background .2s,box-shadow .2s;}
.login-btn:hover{background:#e01f74;box-shadow:0 6px 24px rgba(247,37,133,.4);}
.login-err{margin-top:11px;padding:9px 13px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25);border-radius:8px;font-size:12px;color:#f87171;text-align:center;display:none;}
.login-foot{text-align:center;margin-top:28px;font-size:11px;color:var(--muted2);}
.login-foot strong{color:var(--pk);font-family:var(--mono);}

/* ══ APP ══ */
#app{display:none;position:relative;z-index:1;}

/* ══ TOPNAV ══ */
.topnav{position:sticky;top:0;z-index:100;background:rgba(8,8,8,.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--bd);height:52px;padding:0 20px;display:flex;align-items:center;justify-content:space-between;}
.nav-brand{display:flex;align-items:center;gap:7px;font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted2);}
.nav-dot{width:7px;height:7px;border-radius:50%;background:var(--pk);animation:pulse 2s infinite;}
.nav-r{display:flex;align-items:center;gap:14px;}
.nav-date{font-family:var(--mono);font-size:11px;color:var(--muted);}
.nav-user{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:600;color:var(--pk2);}
.nav-avatar{width:26px;height:26px;border-radius:50%;background:var(--pk3);border:1px solid var(--bd2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--pk);}

/* ══ TAB BAR ══ */
.tabbar{position:sticky;top:52px;z-index:99;background:rgba(8,8,8,.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--bd);padding:0 20px;display:flex;gap:0;overflow-x:auto;}
.tabbar::-webkit-scrollbar{display:none;}
.tab-btn{flex-shrink:0;padding:14px 20px;font-family:var(--font);font-size:13px;font-weight:600;color:var(--muted2);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:color .2s,border .2s;white-space:nowrap;display:flex;align-items:center;gap:7px;}
.tab-btn:hover{color:var(--wh2);}
.tab-btn.active{color:var(--pk);border-bottom-color:var(--pk);}
.tab-dot{width:6px;height:6px;border-radius:50%;background:currentColor;opacity:.6;}
.tab-count{font-family:var(--mono);font-size:9px;background:rgba(247,37,133,.15);color:var(--pk);border-radius:10px;padding:2px 6px;}

/* ══ PAGE ══ */
.set-page{display:none;}
.set-page.active{display:block;}
.page{max-width:1040px;margin:0 auto;padding:48px 20px 90px;}

/* ══ HERO ══ */
.hero{text-align:center;margin-bottom:60px;animation:fadeDown .9s ease both;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:7px;background:rgba(247,37,133,.1);border:1px solid rgba(247,37,133,.25);color:var(--pk);font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;padding:5px 15px;border-radius:30px;margin-bottom:18px;}
.pd{width:6px;height:6px;border-radius:50%;background:var(--pk);animation:pulse 2s infinite;}
.hero h1{font-size:clamp(24px,5vw,52px);font-weight:700;line-height:1.05;letter-spacing:-1px;background:linear-gradient(135deg,#fff 30%,var(--pk) 65%,#ff8cc8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:10px;}
.hero-sub{font-size:14px;color:var(--muted2);margin-bottom:22px;font-weight:300;}
.hero-meta{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap;font-size:11.5px;color:var(--muted2);margin-bottom:20px;}
.hero-sep{color:rgba(255,255,255,.15);}
.speakers{display:flex;justify-content:center;gap:9px;flex-wrap:wrap;}
.sc{display:flex;align-items:center;gap:7px;background:var(--s1);border:1px solid var(--bd);border-radius:30px;padding:5px 13px 5px 5px;font-size:11px;transition:border .2s;}
.sc:hover{border-color:var(--bd2);}
.sa{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;}
.sr{font-size:10px;color:var(--muted2);}

/* ══ SECTION HEADER ══ */
.sh{display:flex;align-items:center;gap:11px;margin-bottom:22px;}
.sh-n{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:2px;padding:4px 10px;border-radius:6px;border:1px solid;flex-shrink:0;}
.sh h2{font-size:17px;font-weight:700;letter-spacing:-.3px;}
.sh hr{flex:1;border:none;border-top:1px solid var(--bd);}

/* ══ SECTION WRAPPERS ══ */
.sec{margin-bottom:60px;animation:fadeUp .7s ease both;}

/* ══ CARDS ══ */
.card{background:var(--s1);border-radius:14px;border:1px solid var(--bd);padding:20px;transition:transform .2s,border .2s,box-shadow .2s;}
.card:hover{transform:translateY(-2px);border-color:rgba(255,255,255,.12);box-shadow:0 10px 36px rgba(0,0,0,.5);}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px;}
@media(max-width:640px){.grid2,.grid3{grid-template-columns:1fr;}}

/* ══ BANNER HIGHLIGHT ══ */
.banner{background:rgba(247,37,133,.06);border:1px solid rgba(247,37,133,.15);border-radius:14px;padding:22px 24px;margin-bottom:18px;}
.banner h3{font-size:clamp(15px,2.5vw,22px);font-weight:700;line-height:1.3;margin-bottom:7px;}
.banner h3 em{color:var(--pk);font-style:normal;}
.banner p{font-size:13px;color:var(--muted2);line-height:1.7;}
.banner-white{background:rgba(255,255,255,.04);border:1px solid var(--bd);}

/* ══ QUOTE BLOCK ══ */
.qblock{padding:14px 18px;background:rgba(247,37,133,.06);border-left:3px solid var(--pk);border-radius:0 10px 10px 0;font-size:14px;font-weight:600;line-height:1.6;margin-bottom:14px;}
.qblock em{color:var(--pk);font-style:normal;}

/* ══ FLOW / PILLS ══ */
.flow-row{display:flex;align-items:center;gap:7px;flex-wrap:wrap;font-size:11.5px;margin-bottom:7px;}
.fbubble{background:rgba(247,37,133,.1);border:1px solid rgba(247,37,133,.2);border-radius:20px;padding:5px 11px;font-weight:600;font-size:11px;color:var(--pk2);white-space:nowrap;}
.farrow{color:var(--muted);font-size:12px;}
.fresult{background:rgba(255,255,255,.07);border:1px solid var(--bd);border-radius:20px;padding:5px 11px;font-weight:700;font-size:11px;color:var(--wh);}

/* ══ TABLE ══ */
.tbl{width:100%;border-collapse:separate;border-spacing:0 4px;}
.tbl thead th{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:9px 13px;color:var(--muted2);text-align:left;}
.tbl tbody td{padding:9px 13px;background:var(--s1);border-top:1px solid rgba(255,255,255,.03);border-bottom:1px solid rgba(255,255,255,.03);font-size:12px;vertical-align:middle;}
.tbl tbody td:first-child{border-radius:10px 0 0 10px;border-left:1px solid rgba(255,255,255,.03);font-family:var(--mono);font-weight:600;font-size:10.5px;color:var(--muted2);}
.tbl tbody td:last-child{border-radius:0 10px 10px 0;border-right:1px solid rgba(255,255,255,.03);}
.tbl tbody tr:hover td{background:rgba(255,255,255,.03);}

/* ══ BAR CHART ══ */
.bar-wrap{display:flex;flex-direction:column;gap:7px;}
.bar-item{display:flex;align-items:center;gap:10px;font-size:12px;}
.bar-label{min-width:180px;text-align:right;color:var(--muted2);font-size:11px;flex-shrink:0;}
.bar-track{flex:1;height:20px;background:rgba(255,255,255,.05);border-radius:4px;overflow:hidden;position:relative;}
.bar-fill{height:100%;border-radius:4px;display:flex;align-items:center;padding-left:8px;font-size:10px;font-weight:700;color:#fff;font-family:var(--mono);transition:width .8s ease;}
.bar-val{font-family:var(--mono);font-size:11px;color:var(--pk2);min-width:38px;}
.bar-top3{border-left:2px solid var(--pk);}
@media(max-width:600px){.bar-label{min-width:120px;font-size:10px;}}

/* ══ DATA TABLE ══ */
.data-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:11px;margin-bottom:16px;}
.data-card{background:var(--s2);border-radius:12px;padding:14px;border:1px solid var(--bd);text-align:center;}
.data-card .dc-num{font-family:var(--mono);font-size:22px;font-weight:700;margin-bottom:4px;}
.data-card .dc-label{font-size:11px;color:var(--muted2);line-height:1.4;}

/* ══ AI vs HUMAN ══ */
.vs-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;}
@media(max-width:500px){.vs-grid{grid-template-columns:1fr;}}
.vs-card{border-radius:14px;padding:20px;}
.vs-card h4{font-size:15px;font-weight:700;margin-bottom:12px;}
.vs-item{display:flex;align-items:flex-start;gap:8px;font-size:12.5px;margin-bottom:7px;line-height:1.5;}
.vs-item .vi{flex-shrink:0;margin-top:2px;}

/* ══ DATA EVOLUTION ══ */
.evo-wrap{display:flex;flex-direction:column;gap:6px;}
.evo-row{display:grid;grid-template-columns:180px 1fr 1fr;gap:10px;align-items:stretch;}
@media(max-width:600px){.evo-row{grid-template-columns:120px 1fr 1fr;}}
.evo-label{display:flex;align-items:center;justify-content:flex-end;padding-right:12px;font-family:var(--mono);font-size:11px;font-weight:700;text-align:right;}
.evo-data{border-radius:9px;padding:10px 13px;font-size:12px;font-weight:600;color:#fff;}
.evo-mkt{background:rgba(255,255,255,.05);border:1px solid var(--bd);border-radius:9px;padding:10px 13px;font-size:11.5px;color:var(--muted2);}

/* ══ PRIORITY MATRIX ══ */
.matrix-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;border:1px solid var(--bd);border-radius:12px;overflow:hidden;margin-bottom:14px;}
.matrix-cell{padding:22px 18px;}
.matrix-cell .mc-title{font-size:16px;font-weight:700;margin-bottom:5px;}
.matrix-cell .mc-desc{font-size:11.5px;color:var(--muted2);line-height:1.5;}
.mc-divider-v{border-left:1px solid var(--bd);}
.mc-divider-h{border-top:1px solid var(--bd);}

/* ══ PLATFORM LIST ══ */
.plat-list{display:flex;flex-direction:column;gap:8px;}
.plat-row{display:grid;grid-template-columns:48px 1fr;align-items:center;gap:13px;background:var(--s1);border-radius:13px;padding:13px 17px;border:1px solid var(--bd);transition:border .2s,transform .2s;}
.plat-row:hover{border-color:var(--bd2);transform:translateX(4px);}
.plat-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;background:#111;}
.p-role{font-size:16px;font-weight:700;}
.p-desc{font-size:11.5px;color:var(--muted2);margin-top:2px;}

/* ══ STEP CARDS ══ */
.steps5{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;}
@media(max-width:640px){.steps5{grid-template-columns:1fr;}}
.step-card{background:var(--s1);border-radius:12px;padding:14px 11px;border:1px solid var(--bd);text-align:center;transition:border .2s,transform .2s;}
.step-card:hover{border-color:var(--bd2);transform:translateY(-3px);}
.step-num{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:12px;font-weight:700;margin:0 auto 8px;}
.step-title{font-size:12px;font-weight:700;line-height:1.3;margin-bottom:4px;}
.step-sub{font-size:10.5px;color:var(--muted2);line-height:1.4;}

/* ══ KEY CARDS (SUMMARY) ══ */
.key-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:9px;}
.key-card{background:rgba(255,255,255,.03);border:1px solid var(--bd);border-radius:11px;padding:13px 14px;display:flex;gap:9px;}
.kn{font-family:var(--mono);font-size:18px;font-weight:700;line-height:1;flex-shrink:0;min-width:20px;}
.kt h5{font-size:12px;font-weight:700;margin-bottom:3px;}
.kt p{font-size:11px;color:var(--muted2);line-height:1.5;}

/* ══ INSIGHT CARD (expanded) ══ */
.insight-block{background:var(--s2);border-radius:13px;padding:18px 20px;border:1px solid var(--bd);margin-bottom:12px;}
.insight-block h4{font-size:14px;font-weight:700;margin-bottom:10px;color:var(--pk2);}
.insight-item{display:flex;align-items:flex-start;gap:9px;font-size:12.5px;margin-bottom:8px;line-height:1.6;}
.insight-item:last-child{margin-bottom:0;}
.i-dot{width:6px;height:6px;border-radius:50%;background:var(--pk);flex-shrink:0;margin-top:6px;}

/* ══ QUOTE SLIDES (Set 3) ══ */
.quote-slides{display:flex;flex-direction:column;gap:10px;}
.qs-item{background:var(--s1);border-radius:14px;padding:20px 22px;border:1px solid var(--bd);transition:border .2s;}
.qs-item:hover{border-color:rgba(247,37,133,.2);}
.qs-main{font-size:clamp(15px,2.5vw,20px);font-weight:700;line-height:1.4;margin-bottom:6px;}
.qs-main em{color:var(--pk);font-style:normal;}
.qs-main .contrast{color:var(--muted2);font-weight:400;}
.qs-insight{font-size:12px;color:var(--muted2);line-height:1.6;padding-top:8px;border-top:1px solid var(--bd);}

/* ══ AI vs BRAND BIG ══ */
.ai-brand-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:18px;border:1px solid var(--bd);border-radius:14px;overflow:hidden;}
.ab-cell{padding:22px;}
.ab-cell h4{font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;font-family:var(--mono);margin-bottom:12px;}
.ab-cell .ab-title{font-size:17px;font-weight:800;margin-bottom:4px;}
.ab-cell .ab-sub{font-size:12px;color:var(--muted2);margin-bottom:14px;line-height:1.5;}
.ab-cell .ab-items{display:flex;flex-direction:column;gap:6px;}
.ab-item{display:flex;align-items:flex-start;gap:8px;font-size:12px;line-height:1.5;}
.ab-item .ai-mark{font-family:var(--mono);font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;flex-shrink:0;margin-top:1px;}
.ab-divider{border-left:1px solid var(--bd);}

/* ══ FOOTER ══ */
.footer{text-align:center;margin-top:52px;padding-top:20px;border-top:1px solid var(--bd);}
.footer-brand{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--pk);margin-bottom:5px;}
.footer-detail{font-size:11px;color:var(--muted);}

/* ══ PROGRESS BAR ══ */
.prog-bar{height:3px;background:rgba(247,37,133,.15);position:fixed;top:0;left:0;right:0;z-index:200;}
.prog-fill{height:100%;background:var(--pk);width:0;transition:width .3s;}

/* ══ ANIMATIONS ══ */
@keyframes fadeDown{from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}
</style>
</head>
<body>

<div class="prog-bar"><div class="prog-fill" id="prog"></div></div>

<!-- ════════════════════ LOGIN ════════════════════ -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">
      <div class="eyebrow"><span class="eyebrow-dot"></span>Martech Expo 2026 · All Sets</div>
      <h2>Recap by<br>NitrogenZ.</h2>
      <p>Enter password to access</p>
    </div>
    <div class="lf"><label>Password</label><input type="password" id="pw" placeholder="••••••••" autocomplete="off"></div>
    <button class="login-btn" onclick="doLogin()">Enter →</button>
    <div class="login-err" id="login-err">Incorrect password. Try again.</div>
    <div class="login-foot"><strong>NitrogenZ.</strong> · 24 Mar 2026</div>
  </div>
</div>

<!-- ════════════════════ APP ════════════════════ -->
<div id="app">

<nav class="topnav">
  <div class="nav-brand"><div class="nav-dot"></div>Martech 2026</div>
  <div class="nav-r">
    <div class="nav-date">24 Mar 2026</div>
    <div class="nav-user"><div class="nav-avatar">N</div>NitrogenZ.</div>
  </div>
</nav>

<div class="tabbar">
  <button class="tab-btn active" onclick="switchTab(0,this)">
    <div class="tab-dot"></div>Set 1 — Social Media &amp; Influencer
    <span class="tab-count">9</span>
  </button>
  <button class="tab-btn" onclick="switchTab(1,this)">
    <div class="tab-dot"></div>Set 2 — Digital Marketing &amp; Consumer
    <span class="tab-count">8</span>
  </button>
  <button class="tab-btn" onclick="switchTab(2,this)">
    <div class="tab-dot"></div>Set 3 — Big Brands &amp; AI Era
    <span class="tab-count">7</span>
  </button>
</div>

<!-- ══════════════════════════════════════════
  SET 1 — Social Media & Influencer Trends 2026
══════════════════════════════════════════ -->
<div class="set-page active" id="set0">
<div class="page">
  <div class="hero">
